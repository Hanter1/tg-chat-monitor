# Токен бота от @BotFather (aiogram). На Android опционален.
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram API credentials — https://my.telegram.org/apps (Telethon)
API_ID=12345678
API_HASH=your_api_hash_here

# Имя файла сессии Telethon (создаётся при первом запуске)
TELETHON_SESSION=monitor_session

# Telegram user ID администратора — для бота и дублирования уведомлений в ЛС.
# На Android можно не задавать: подставится ID аккаунта Telethon после входа.
ADMIN_USER_ID=123456789

# Дублировать уведомления о совпадениях в Telegram (нужен BOT_TOKEN).
# 0 = только локальные уведомления приложения (по умолчанию на Android)
# 1 = также слать в ЛС через бота
TELEGRAM_NOTIFY=1

# Путь к SQLite-базе
DATABASE_URL=sqlite+aiosqlite:///./monitor.db

# Интервал опроса чатов (секунды)
POLL_INTERVAL=10

# Мониторинг / сканирование (значения по умолчанию при первом запуске)
# Период: 1, 3, 7, 14, 30, 90, 365 дней или 0 (вся история)
SCAN_PERIOD_DAYS=7
# Лимит: до N сообщений в чате (timeline) или совпадений на слово (search)
SCAN_HISTORY_LIMIT=100
# Режим: timeline (по периоду) или search (поиск Telegram)
SCAN_MODE=timeline
