# Токен бота от @BotFather (aiogram)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram API credentials — https://my.telegram.org/apps (Telethon)
API_ID=12345678
API_HASH=your_api_hash_here

# Имя файла сессии Telethon (создаётся при первом запуске)
TELETHON_SESSION=monitor_session

# Telegram user ID администратора — получает уведомления в ЛС
ADMIN_USER_ID=123456789

# Путь к SQLite-базе
DATABASE_URL=sqlite+aiosqlite:///./monitor.db

# Интервал опроса чатов (секунды)
POLL_INTERVAL=10
